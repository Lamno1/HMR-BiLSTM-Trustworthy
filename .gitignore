# =============================================
# HMR-BiLSTM Project .gitignore
# =============================================

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.pytest_cache/
*.egg-info/

# ---------- Virtual Environments ----------
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# ---------- IDE / Editor ----------
.vscode/
.idea/
*.swp
*.swo
*~
.spyderproject
.spyproject
*.sublime-project
*.sublime-workspace

# ---------- OS ----------
Thumbs.db
.DS_Store
desktop.ini
.Spotlight-V100
.Trashes

# ---------- Data (large raw files only) ----------
data/raw/

# ---------- Temporary / utility / logs ----------
*.log
*.tmp
check_progress.py
tempCodeRunnerFile.py
*.ipynb_checkpoints
.ipynb_checkpoints/

# ---------- Results (logs only, keep tables & figures) ----------
# results/ is tracked, but individual logs may be regenerated
results/logs/*.json
results/logs/*.tmp

# ---------- Models / Checkpoints ----------
*.pt
*.pth
results/checkpoints/

# ---------- Processed Data ----------
data/processed/

# ---------- Output Runs ----------
outputs/v1.0_*/
